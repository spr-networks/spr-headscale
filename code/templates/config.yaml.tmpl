# Headscale configuration generated by the spr-headscale plugin.
# DO NOT EDIT — this file is regenerated from the plugin config
# (/configs/spr-headscale/config.json) on every start and config change.
---
server_url: "{{ .ServerURL }}"

# Bind only to the container IP on the spr-headscale docker bridge.
# No host ports are published; exposure is controlled by SPR policies/groups.
listen_addr: "{{ .ListenAddr }}"

# Metrics/debug listener disabled.
metrics_listen_addr: ""

# Remote gRPC stays off: without TLS and with grpc_allow_insecure false,
# headscale never opens the TCP gRPC listener. The CLI uses the unix socket.
grpc_listen_addr: "127.0.0.1:50443"
grpc_allow_insecure: false

trusted_proxies: []

noise:
  private_key_path: "{{ .NoiseKeyPath }}"

prefixes:
  v4: 100.64.0.0/10
  v6: fd7a:115c:a1e0::/48
  allocation: sequential

derp:
  server:
    # Embedded DERP is off (it would require TLS on server_url).
    enabled: false
  urls:
    - https://controlplane.tailscale.com/derpmap/default
  paths: []
  auto_update_enabled: true
  update_frequency: 3h

disable_check_updates: true

node:
  expiry: 0
  ephemeral:
    inactivity_timeout: 30m

database:
  type: sqlite
  sqlite:
    path: "{{ .DBPath }}"
    write_ahead_log: true

acme_url: https://acme-v02.api.letsencrypt.org/directory
acme_email: ""
tls_letsencrypt_hostname: ""
tls_cert_path: ""
tls_key_path: ""

log:
  level: info
  format: text

policy:
  mode: file
  path: ""

dns:
  magic_dns: {{ .MagicDNS }}
  base_domain: "{{ .BaseDomain }}"
  override_local_dns: false
  nameservers:
    global:
      - 1.1.1.1
      - 1.0.0.1
    split: {}
  search_domains: []
  extra_records: []

unix_socket: "{{ .SocketPath }}"
unix_socket_permission: "0770"

logtail:
  enabled: false
